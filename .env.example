# Postgres — ставится автоматически интеграцией в Vercel → Storage:
# Supabase даёт POSTGRES_URL, Neon даёт DATABASE_URL. Подойдёт любая из двух.
POSTGRES_URL=
DATABASE_URL=

# Токен бота из @BotFather
TELEGRAM_BOT_TOKEN=

# Любая случайная строка — защита крон-эндпоинта и вебхука
CRON_SECRET=

# Необязательно: пароль на веб-интерфейс (пусто = без пароля)
APP_PASSWORD=

# Необязательно: публичный URL приложения (на Vercel определяется сам)
APP_URL=
