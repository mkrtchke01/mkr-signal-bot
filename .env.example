# Neon Postgres — ставится автоматически интеграцией Neon в Vercel
DATABASE_URL=

# Токен бота из @BotFather
TELEGRAM_BOT_TOKEN=

# Любая случайная строка — защита крон-эндпоинта и вебхука
CRON_SECRET=

# Необязательно: пароль на веб-интерфейс (пусто = без пароля)
APP_PASSWORD=

# Необязательно: публичный URL приложения (на Vercel определяется сам)
APP_URL=
